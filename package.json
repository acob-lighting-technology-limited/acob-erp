{
  "name": "acob-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/clean-next.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:strict": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commit": "cz",
    "type-check": "tsc --noEmit",
    "test:audit": "tsx --test lib/audit/__tests__/*.test.ts",
    "test:campaign": "tsx scripts/test-campaign/run.ts",
    "test:campaign:inventory": "tsx scripts/test-campaign/run.ts --inventory-only",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ui:ensure-loading": "node scripts/ui/ensure-loading.mjs",
    "ui:audit": "node scripts/ui/audit-reusables.mjs",
    "ui:audit:baseline": "node scripts/ui/audit-reusables.mjs --write-allowlist",
    "check-all": "npm run lint && npm run format:check && npm run type-check && npm run ui:audit",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
