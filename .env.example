# ============================================================
# Required — Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================
# Required — Email (Resend)
# ============================================================
RESEND_API_KEY=re_your_key

# ============================================================
# Required — Site URL
# ============================================================
NEXT_PUBLIC_SITE_URL=https://erp.yourdomain.com
NEXT_PUBLIC_APP_URL=https://erp.yourdomain.com

# ============================================================
# Organisation identity (optional — sensible defaults shown)
# ============================================================
NEXT_PUBLIC_ORG_CODE=ACOB
NEXT_PUBLIC_ORG_PRIMARY_DOMAIN=acoblighting.com
NEXT_PUBLIC_ORG_STAFF_DOMAIN=org.acoblighting.com
NEXT_PUBLIC_ORG_ICT_EMAIL=ict@acoblighting.com
ORG_NOTIFICATION_SENDER=ACOB Internal Systems <notifications@acoblighting.com>
MEETING_CONTACT_EMAIL=e.rafiat@org.acoblighting.com
ICT_SUPPORT_EMAIL=ict@acoblighting.com
NOTIFICATION_SENDER_EMAIL=notifications@acoblighting.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Business hours for SLA calculations (24-h, optional)
# ============================================================
BUSINESS_HOUR_START=9
BUSINESS_HOUR_END=18

# ============================================================
# Help-desk SLA budgets (optional — values shown are defaults)
# ============================================================
SLA_URGENT_HOURS=4
SLA_HIGH_HOURS=24
SLA_MEDIUM_DAYS=3
SLA_LOW_DAYS=7

# ============================================================
# Microsoft OneDrive integration (optional)
# ============================================================
AZURE_CLIENT_ID=your_client_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_SECRET=your_client_secret
ONEDRIVE_ENABLED=false
ONEDRIVE_SITE_ID=
ONEDRIVE_SITE_HOSTNAME=yourtenant.sharepoint.com
ONEDRIVE_SITE_PATH=/sites/your-site-name

ONEDRIVE_DRIVE_ID=
ONEDRIVE_DRIVE_NAME=
ONEDRIVE_PROJECTS_FOLDER=Projects
ONEDRIVE_PAYMENTS_FOLDER=Payments
ONEDRIVE_USER_EMAIL=user@yourdomain.com

# ============================================================
# Feature flags (optional)
# ============================================================
HELP_DESK_EMAIL_ENABLED=true
LEAVE_EMAIL_NOTIFICATIONS_ENABLED=true
HELP_DESK_TEST_RECIPIENT=

# ============================================================
# Cron / scheduled tasks
# ============================================================
CRON_SECRET=your_cron_secret
